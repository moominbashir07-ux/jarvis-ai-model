{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "lib": ["ES2020", "DOM"],
    "ignoreDeprecations": "6.0"
  },
  "include": ["electron/**/*"]
}
