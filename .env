# JARVIS AI OS Configuration Profile
JARVIS_ENV=development
LOG_LEVEL=DEBUG

# AI Brain API Keys (Replace with actual keys)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Voice (TTS / STT) Settings
VOICE_ENABLED=true
WAKE_WORD=jarvis
ENERGY_THRESHOLD=300
SILENCE_DURATION=1.5
STT_PROVIDER=google  # Options: google, openai
VOICE_PROVIDER=system  # Options: system, elevenlabs, openai
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
TTS_VOICE_ID=
PTT_KEY=ctrl+space

# Memory Settings
MEMORY_DB_PATH=jarvis_memory.db

# Vision Settings
VISION_ENABLED=false
WEBCAM_INDEX=0

# Automation Settings
ALLOW_UNSAFE_COMMANDS=false
